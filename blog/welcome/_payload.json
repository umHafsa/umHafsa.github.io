shiki-dark-text-decoration);}",{"title":56,"searchDepth":79,"depth":79,"links":624},[625,626,630,631],{"id":33,"depth":79,"text":34},{"id":40,"depth":79,"text":41,"children":627},[628,629],{"id":45,"depth":86,"text":46},{"id":128,"depth":86,"text":129},{"id":135,"depth":79,"text":136},{"id":594,"depth":79,"text":595},"2026-03-01","A quiet corner of the internet where I share thoughts on motherhood, technology, and the spaces in between.",false,"md",null,"en",{},"/blog/welcome",{"title":5,"description":633},"blog/welcome",[643,644],"personal","beginnings","HoMgMxLMqmLeEmDR1P6z6vlNuz34s0WdMeCVQWCsmmI",[647,887,1342],{"id":648,"title":649,"body":650,"category":128,"date":632,"description":877,"draft":634,"extension":635,"image":636,"lang":878,"meta":879,"navigation":114,"path":880,"seo":881,"stem":882,"tags":883,"__hash__":886},"blog/blog/ar/marhaba.md","مرحبًا بكم في مساحتي الرقمية",{"type":7,"value":651,"toc":869},[652,655,658,669,673,676,680,683,686,733,736,739,743,746,857,859,862,867],[10,653,654],{"id":654},"مرحبًا",[15,656,657],{},"هذه مساحتي الرقمية — ركنٌ هادئ على الإنترنت، بعيدًا عن ضجيج وسائل التواصل الاجتماعي.",[15,659,660,661,664,665,668],{},"هنا أكتب عن الأشياء التي تملأ أيامي: ",[22,662,663],{},"الأمومة","، و",[22,666,667],{},"التكنولوجيا","، واللحظات الصغيرة الهادئة التي تشكّل الحياة.",[31,670,672],{"id":671},"لماذا-هذه-المساحة","لماذا هذه المساحة؟",[15,674,675],{},"ابتعدت عن وسائل التواصل الاجتماعي منذ فترة. ليس غضبًا أو إحباطًا، بل رغبةً في شيء أكثر قصدية. أردت مكانًا تتنفس فيه كلماتي — حيث أستطيع التفكير ببطء والمشاركة بتعمّد.",[31,677,679],{"id":678},"ماذا-ستجدون-هنا","ماذا ستجدون هنا؟",[43,681,682],{"id":682},"التقنية",[15,684,685],{},"أنا في رحلة عودة إلى عالم التكنولوجيا. سأشارك ما أتعلمه والمشاريع التي أبنيها والتحديات التي أواجهها. إليكم لمحة بسيطة:",[51,687,689],{"className":53,"code":688,"language":55,"meta":56,"style":56},"def مرحبا():\n    \"\"\"بداية صغيرة.\"\"\"\n    print(\"مرحبًا من مساحة أم حفصة الرقمية!\")\n    return True\n\nمرحبا()\n