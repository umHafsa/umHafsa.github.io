[{"data":1,"prerenderedAt":2331},["ShallowReactive",2],{"blog-/blog/welcome":3,"blog-all-en":646},{"id":4,"title":5,"body":6,"category":128,"date":632,"description":633,"draft":634,"extension":635,"image":636,"lang":637,"meta":638,"navigation":114,"path":639,"seo":640,"stem":641,"tags":642,"__hash__":645},"blog/blog/welcome.md","Welcome to My Digital Space",{"type":7,"value":8,"toc":623},"minimark",[9,14,18,30,35,38,42,47,50,126,130,133,137,140,298,592,596,599,607,610,613,619],[10,11,13],"h1",{"id":12},"welcome","Welcome",[15,16,17],"p",{},"This is my digital space — a quiet corner of the internet, far from the noise of social media.",[15,19,20,21,25,26,29],{},"Here, I write about the things I want to tell: ",[22,23,24],"strong",{},"motherhood",", ",[22,27,28],{},"technology",", and the small, quiet moments that make up a life.",[31,32,34],"h2",{"id":33},"why-this-space","Why This Space?",[15,36,37],{},"I stepped away from social media a while ago. Not out of anger or frustration, but out of a desire for something more intentional. I wanted a place where my words could breathe — where I could think slowly and share deliberately.",[31,39,41],{"id":40},"what-youll-find-here","What You'll Find Here",[43,44,46],"h3",{"id":45},"tech","Tech",[15,48,49],{},"I'm on a journey back into the tech world. I'll share what I'm learning, the projects I'm building, and the challenges I encounter along the way. Here's a taste — a simple Python snippet:",[51,52,57],"pre",{"className":53,"code":54,"language":55,"meta":56,"style":56},"language-python shiki shiki-themes rose-pine-dawn rose-pine","def hello():\n    \"\"\"A small beginning.\"\"\"\n    print(\"Hello from UmHafsa's digital space!\")\n    return True\n\nhello()\n","python","",[58,59,60,77,84,100,109,116],"code",{"__ignoreMap":56},[61,62,65,69,73],"span",{"class":63,"line":64},"line",1,[61,66,68],{"class":67},"siNMX","def",[61,70,72],{"class":71},"sOm3O"," hello",[61,74,76],{"class":75},"sUa3U","():\n",[61,78,80],{"class":63,"