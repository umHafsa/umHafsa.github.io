.s06kO{--shiki-default:#56949F;--shiki-dark:#9CCFD8}",{"title":55,"searchDepth":78,"depth":78,"links":2100},[2101,2102,2103,2104,2105],{"id":900,"depth":78,"text":901},{"id":932,"depth":78,"text":933},{"id":1021,"depth":78,"text":1022},{"id":1188,"depth":78,"text":1189},{"id":2075,"depth":78,"text":2076},"2026-02-28","A beginner-friendly guide to writing your first Python program — my notes as I dive back into coding.",{},"/blog/getting-started-with-python",{"title":889,"description":2107},"blog/getting-started-with-python",[54,2113,2114],"learning","coding","CCEvrjb0ONhrcKPRLSc79OeZ4KCv84ZZDqSavg7YG28",[2117,2144,2170],{"id":2118,"title":2119,"body":2120,"category":320,"date":321,"description":2136,"draft":323,"extension":324,"lang":326,"meta":2137,"navigation":113,"path":2138,"seo":2139,"stem":2140,"tags":2141,"__hash__":2143},"notes/notes/ar/first-note.md","First Note",{"type":8,"value":2121,"toc":2134},[2122,2125,2128,2131],[15,2123,2124],{},"اليوم أنشأت مساحتي الرقمية.",[15,2126,2127],{},"بلا إعجابات، بلا متابعين، بلا خوارزميات — فقط كلمات ونيّة.",[15,2129,2130],{},"هناك شيء محرّر في الكتابة لا لأحد بعينه. أو ربما لشخص واحد. ربما لنفسي المستقبلية، وهي تنظر إلى الوراء.",[15,2132,2133],{},"الإنترنت لا يجب أن يكون صاخبًا. يمكن أن يكون حديقة، تُعتنى بها بهدوء. 🌿",{"title":55,"searchDepth":78,"depth":78,"links":2135},[],"اليوم أنشأت مساحتي الرقمية. بلا إعجابات، بلا متابعين، بلا خوارزميات — فقط كلمات ونيّة.",{},"/notes/ar/first-note",{"description":2136},"notes/ar/first-note",[2142],"تأمل","gaZpfc0L2Gigm5jyLl2IrKk00PS2Km2aelUlaNw4drw",{"id":2145,"title":2119,"body":2146,"category":320,"date":321,"description":2162,"draft":323,"extension":324,"lang":878,"meta":2163,"navigation":113,"path":2164,"seo":2165,"stem":2166,"tags":2167,"__hash__":2169},"notes/notes/first-note.md",{"type":8,"value":2147,"toc":2160},[2148,2151,2154,2157],[15,2149,2150],{},"Today I set up my digital space.",[15,2152,2153],{},"No likes, no followers, no algorithms — just words and intention.",[15,2155,2156],{},"There's something liberating about writing for no one in particular. Or maybe for one person. Maybe for my future self, looking back.",[15,2158,2159],{},"The internet doesn't have to be noisy. It can be a garden, tended quietly. 🌿",{"title":55,"searchDepth":78,"depth":78,"links":2161},[],"Today I set up my digital space. No likes, no followers, no algorithms — just words and intention.",{},"/notes/first-note",{"description":2162},"notes/first-note",[2168],"reflection","VJviHb8YPfQLR-ujq5giM8wxfNvzot7F6Ucv-87ItO0",{"id":2171,"title":2172,"body":2173,"category":371,"date":2106,"description":2241,"draft":323,"extension":324,"lang":878,"meta":2242,"navigation":113,"path":2243,"seo":2244,"stem":2245,"tags":2246,"__hash__":2247},"notes/notes/learning-python.md","Learning Python",{"type":8,"value":2174,"toc":2239},[2175,2178,2181,2233,2236],[15,2176,2177],{},"Started learning Python today.",[15,2179,2180],{},"First function written. First bug fixed. First \"aha!\" moment.",[50,2182,2184],{"className":52,"code":2183,"language":54,"meta":55,"style":55},"# My first bug: forgot the colon\ndef greet(name)  # \u003C- spot the missing ':'\n    print(f\"Hello, {name}!\")\n",[57,2185,2186,2193,2212],{"__ignoreMap":55},[60,2187,2188,2190],{"class":62,"line":63},[60,2189,951],{"class":950},[60,2191,2192],{"class":954}," My first bug: forgot the colon\n",[60,2194,2195,2197,2200,2202,2204,2206,2209],{"class":62,"line":78},[60,2196,67],{"class":66},[60,2198,2199],{"class":70}," greet",[60,2201,92],{"class":74},[60,2203,995],{"class":1211},[60,2205,1221],{"class":74},[60,2207,2208],{"class":950},"  #",[60,2210,2211],{"class":954}," \u003C- spot the missing ':'\n",[60,2213,2214,2216,2218,2220,2222,2224,2226,2228,2231],{"class":62,"line":85},[60,2215,89],{"class":88},[60,2217,92],{"class":74},[60,2219,986],{"class":66},[60,2221,989],{"class":81},[60,2223,992],{"class":66},[60,2225,995],{"class":120},[60,2227,998],{"class":66},[60,2229,2230],{"class":81},"!\"",[60,2232,98],{