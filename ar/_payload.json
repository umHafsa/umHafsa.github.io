[{"data":1,"prerenderedAt":2248},["ShallowReactive",2],{"recent-posts":3,"recent-notes":2116},[4,335,887],{"id":5,"title":6,"body":7,"category":320,"date":321,"description":322,"draft":323,"extension":324,"image":325,"lang":326,"meta":327,"navigation":113,"path":328,"seo":329,"stem":330,"tags":331,"__hash__":334},"blog/blog/ar/marhaba.md","مرحبًا بكم في مساحتي الرقمية",{"type":8,"value":9,"toc":312},"minimark",[10,14,18,30,35,38,42,46,49,125,128,131,135,138,296,299,302,308],[11,12,13],"h1",{"id":13},"مرحبًا",[15,16,17],"p",{},"هذه مساحتي الرقمية — ركنٌ هادئ على الإنترنت، بعيدًا عن ضجيج وسائل التواصل الاجتماعي.",[15,19,20,21,25,26,29],{},"هنا أكتب عن الأشياء التي تملأ أيامي: ",[22,23,24],"strong",{},"الأمومة","، و",[22,27,28],{},"التكنولوجيا","، واللحظات الصغيرة الهادئة التي تشكّل الحياة.",[31,32,34],"h2",{"id":33},"لماذا-هذه-المساحة","لماذا هذه المساحة؟",[15,36,37],{},"ابتعدت عن وسائل التواصل الاجتماعي منذ فترة. ليس غضبًا أو إحباطًا، بل رغبةً في شيء أكثر قصدية. أردت مكانًا تتنفس فيه كلماتي — حيث أستطيع التفكير ببطء والمشاركة بتعمّد.",[31,39,41],{"id":40},"ماذا-ستجدون-هنا","ماذا ستجدون هنا؟",[43,44,45],"h3",{"id":45},"التقنية",[15,47,48],{},"أنا في رحلة عودة إلى عالم التكنولوجيا. سأشارك ما أتعلمه والمشاريع التي أبنيها والتحديات التي أواجهها. إليكم لمحة بسيطة:",[50,51,56],"pre",{"className":52,"code":53,"language":54,"meta":55,"style":55},"language-python shiki shiki-themes rose-pine-dawn rose-pine","def مرحبا():\n    \"\"\"بداية صغيرة.\"\"\"\n    print(\"مرحبًا من مساحة أم حفصة الرقمية!\")\n    return True\n\nمرحبا()\n","python","",[57,58,59,76,83,99,108,115],"code",{"__ignoreMap":55},[60,61,64,68,72],"span",{"class":62,"line":63},"line",1,[60,65,67],{"class":66},"siNMX","def",[60,69,71],{"class":70},"sOm3O"," مرحبا",[60,73,75],{"class":74},"sUa3U","():\n",[60,77,79],{"class":62,"line":78},2,[60,80,82],{"class":81},"sgdKc","    \"\"\"بداية صغيرة.\"\"\"\n",[60,84,86,90,93,96],{"class":62,"line":85},3,[60,87,89],{"class":88},"sn8lG","    print",[60,91,92],{"class":74},