[{"data":1,"prerenderedAt":1919},["ShallowReactive",2],{"recent-posts":3,"recent-notes":1875},[4,646],{"id":5,"title":6,"body":7,"category":129,"date":633,"description":634,"draft":115,"extension":635,"image":636,"lang":637,"meta":638,"navigation":115,"path":639,"seo":640,"stem":641,"tags":642,"__hash__":645},"blog/blog/welcome.md","Welcome to My Digital Space",{"type":8,"value":9,"toc":624},"minimark",[10,15,19,31,36,39,43,48,51,127,131,134,138,141,299,593,597,600,608,611,614,620],[11,12,14],"h1",{"id":13},"welcome","Welcome",[16,17,18],"p",{},"This is my digital space — a quiet corner of the internet, far from the noise of social media.",[16,20,21,22,26,27,30],{},"Here, I write about the things I want to tell: ",[23,24,25],"strong",{},"motherhood",", ",[23,28,29],{},"technology",", and the small, quiet moments that make up a life.",[32,33,35],"h2",{"id":34},"why-this-space","Why This Space?",[16,37,38],{},"I stepped away from social media a while ago. Not out of anger or frustration, but out of a desire for something more intentional. I wanted a place where my words could breathe — where I could think slowly and share deliberately.",[32,40,42],{"id":41},"what-youll-find-here","What You'll Find Here",[44,45,47],"h3",{"id":46},"tech","Tech",[16,49,50],{},"I'm on a journey back into the tech world. I'll share what I'm learning, the projects I'm building, and the challenges I encounter along the way. Here's a taste — a simple Python snippet:",[52,53,58],"pre",{"className":54,"code":55,"language":56,"meta":57,"style":57},"language-python shiki shiki-themes rose-pine-dawn rose-pine","def hello():\n    \"\"\"A small beginning.\"\"\"\n    print(\"Hello from UmHafsa's digital space!\")\n    return True\n\nhello()\n","python","",[59,60,61,78,85,101,110,117],"code",{"__ignoreMap":57},[62,63,66,70,74],"span",{"class":64,"line":65},"line",1,[62,67,69],{"class":68},"siNMX","def",[62,71,73],{"class":72},"sOm3O"," hello",[62,75,77],{"class":76},"sUa3U","():\n",[62,79,81],{"class"