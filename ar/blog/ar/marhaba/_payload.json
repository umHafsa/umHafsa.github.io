[{"data":1,"prerenderedAt":2321},["ShallowReactive",2],{"blog-/blog/ar/marhaba":3,"blog-all-ar":334},{"id":4,"title":5,"body":6,"category":319,"date":320,"description":321,"draft":322,"extension":323,"image":324,"lang":325,"meta":326,"navigation":112,"path":327,"seo":328,"stem":329,"tags":330,"__hash__":333},"blog/blog/ar/marhaba.md","مرحبًا بكم في مساحتي الرقمية",{"type":7,"value":8,"toc":311},"minimark",[9,13,17,29,34,37,41,45,48,124,127,130,134,137,295,298,301,307],[10,11,12],"h1",{"id":12},"مرحبًا",[14,15,16],"p",{},"هذه مساحتي الرقمية — ركنٌ هادئ على الإنترنت، بعيدًا عن ضجيج وسائل التواصل الاجتماعي.",[14,18,19,20,24,25,28],{},"هنا أكتب عن الأشياء التي تملأ أيامي: ",[21,22,23],"strong",{},"الأمومة","، و",[21,26,27],{},"التكنولوجيا","، واللحظات الصغيرة الهادئة التي تشكّل الحياة.",[30,31,33],"h2",{"id":32},"لماذا-هذه-المساحة","لماذا هذه المساحة؟",[14,35,36],{},"ابتعدت عن وسائل التواصل الاجتماعي منذ فترة. ليس غضبًا أو إحباطًا، بل رغبةً في شيء أكثر قصدية. أردت مكانًا تتنفس فيه كلماتي — حيث أستطيع التفكير ببطء والمشاركة بتعمّد.",[30,38,40],{"id":39},"ماذا-ستجدون-هنا","ماذا ستجدون هنا؟",[42,43,44],"h3",{"id":44},"التقنية",[14,46,47],{},"أنا في رحلة عودة إلى عالم التكنولوجيا. سأشارك ما أتعلمه والمشاريع التي أبنيها والتحديات التي أواجهها. إليكم لمحة بسيطة:",[49,50,55],"pre",{"className":51,"code":52,"language":53,"meta":54,"style":54},"language-python shiki shiki-themes rose-pine-dawn rose-pine","def مرحبا():\n    \"\"\"بداية صغيرة.\"\"\"\n    print(\"مرحبًا من مساحة أم حفصة الرقمية!\")\n    return True\n\nمرحبا()\n","python","",[56,57,58,75,82,98,107,114],"code",{"__ignoreMap":54},[59,60,63,67,71],"span",{"class":61,"line":62},"line",1,[59,64,66],{"class":65},"siNMX","def",[59,68,70],{"class":69},"sOm3O"," مرحبا",[59,72,74],{"class":73},"sUa3U","():\n",[59,76,78],{"class":61,"line":77},2,[59,79,81],{"class":80},"sgdKc","    \"\"\"بداية صغيرة.\"\"\"\n",[59,83,85,89,92,95],{"class":61,"line":84},3,[59,86,88],{"class":87},"sn8lG","    print",[59,90,91],{"class":73},"(",[59,93,94],{"class":80},"\"مرحبًا من مساحة أم حفصة الرقمية!\"",[59,96,97],{"class":73},")\n",[59,99,101,104],{"class":61,"line":100},4,[59,102,103],{"class":65},"    return",[59,105,106],{"class":69}," True\n",[59,108,110],{"class":61,"line":109},5,[59,111,113],{"emptyLinePlaceholder":112},true,"\n",[59,115,117,121],{"class":61,"line":116},6,[59,118,120],{"class":119},"spmHm","مرحبا",[59,122,123],{"class":73},"()\n",[42,125,126],{"id":126},"الحياة",[14,128,129],{},"الأمومة غيّرت كل شيء — أولوياتي، ومنظوري، وعلاقتي بالوقت. سأكتب عن الفوضى الجميلة، والأشياء التي لا يخبرك بها أحد، والحكمة التي تأتي من مشاهدة إنسان صغير يكتشف العالم.",[30,131,133],{"id":132},"القليل-من-الرياضيات","القليل من الرياضيات",[14,135,136],{},"لأن.. لمَ لا؟ إليكم متطابقة أويلر، واحدة من أجمل المعادلات في الرياضيات:",[14,138,139],{},[59,140,143,191],{"className":141},[142],"katex",[59,144,147],{"className":145},[146],"katex-mathml",[148,149,151],"math",{"xmlns":150},"http://www.w3.org/1998/Math/MathML",[152,153,154,186],"semantics",{},[155,156,157,172,176,180,183],"mrow",{},[158,159,160,164],"msup",{},[161,162,163],"mi",{},"e",[155,165,166,169],{},[161,167,168],{},"i",[161,170,171],{},"π",[173,174,175],"mo",{},"+",[177,178,179],"mn",{},"1",[173,181,182],{},"=",[177,184,185],{},"0",[187,188,190],"annotation",{"encoding":189},"application/x-tex","e^{i\\pi} + 1 = 0",[59,192,196,265,286],{"className":193,"ariaHidden":195},[194],"katex-html","true",[59,197,200,205,253,258,262],{"className":198},[199],"base",[59,201],{"className":202,"style":204},[203],"strut","height:0.908em;vertical-align:-0.0833em;",[59,206,209,213],{"className":207},[208],"mord",[59,210,163],{"className":211},[208,212],"mathnormal",[59,214,217],{"className":215},[216],"msupsub",[59,218,221],{"className":219},[220],"vlist-t",[59,222,225],{"className":223},[224],"vlist-r",[59,226,230],{"className":227,"style":229},[228],"vlist","height:0.8247em;",[59,231,233,238],{"style":232},"top:-3.063em;margin-right:0.05em;",[59,234],{"className":2