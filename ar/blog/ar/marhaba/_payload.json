522,300],{},[14,524,525],{},[304,526,306],{},[308,528,310],{},{"title":54,"searchDepth":77,"depth":77,"links":530},[531,532,536],{"id":32,"depth":77,"text":33},{"id":39,"depth":77,"text":40,"children":533},[534,535],{"id":44,"depth":84,"text":44},{"id":126,"depth":84,"text":126},{"id":132,"depth":77,"text":133},{},{"title":5,"description":321},[331,332],{"id":541,"title":542,"body":543,"category":319,"date":320,"description":1082,"draft":322,"extension":323,"image":324,"lang":1083,"meta":1084,"navigation":112,"path":1085,"seo":1086,"stem":1087,"tags":1088,"__hash__":1091},"blog/blog/welcome.md","Welcome to My Digital Space",{"type":7,"value":544,"toc":1073},[545,549,552,563,567,570,574,578,581,628,631,634,638,641,752,1046,1050,1053,1061,1063,1066,1071],[10,546,548],{"id":547},"welcome","Welcome",[14,550,551],{},"This is my digital space — a quiet corner of the internet, far from the noise of social media.",[14,553,554,555,558,559,562],{},"Here, I write about the things I want to tell: ",[21,556,557],{},"motherhood",", ",[21,560,561],{},"technology",", and the small, quiet moments that make up a life.",[30,564,566],{"id":565},"why-this-space","Why This Space?",[14,568,569],{},"I stepped away from social media a while ago. Not out of anger or frustration, but out of a desire for something more intentional. I wanted a place where my words could breathe — where I could think slowly and share deliberately.",[30,571,573],{"id":572},"what-youll-find-here","What You'll Find Here",[42,575,577],{"id":576},"tech","Tech",[14,579,580],{},"I'm on a journey back into the tech world. I'll share what I'm learning, the projects I'm building, and the challenges I encounter along the way. Here's a taste — a simple Python snippet:",[49,582,584],{"className":51,"code":583,"language":53,"meta":54,"style":54},"def hello():\n    \"\"\"A small beginning.\"\"\"\n    print(\"Hello from UmHafsa's digital space!\")\n    return True\n\nhello()\n",[56,585,586,595,600,611,617,621],{"__ignoreMap":54},[59,587,588,590,593],{"class":61,"line":62},[59,589,66],{"class":65},[59,591,592],{"class":69}," hello",[59,594,74],{"class":73},[59,596,597],{"class":61,"line":77},[59,598,599],{"class":80},"    \"\"\"A small beginning.\"\"\"\n",[59,601,602,604,606,609],{"class":61,"line":84},[59,603,88],{"class":87},[59,605,91],{"class":73},[59,607,608],{"class":80},"\"Hello from UmHafsa's digital space!\"",[59,610,97],{"class":73},[59,612,613,615],{"class":61,"line":100},[59,614,103],{"class":65},[59,616,106],{"class":69},[59,618,619],{"class":61,"line":109},[59,620,113],{"emptyLinePlaceholder":112},[59,622,623,626],{"class":61,"line":116},[59,624,625],{"class":119},"hello",[59,627,123],{"class":73},[42,629,630],{"id":319},"Life",[14,632,633],{},"Motherhood changed everything — my priorities, my perspective, my relationship with time. I'll write about the beautiful chaos, the things no one tells you, and the wisdom that comes from watching a tiny human discover the world.",[30,635,637],{"id":636},"a-little-math","A Little Math",[14,639,640],{},"Because why not? Here's Euler's identity, one of the most beautiful equations in mathematics:",[14,642,643],{},[59,644,646,675],{"className":645},[142],[59,647,649],{"className":648},[146],[148,650,651],{"xmlns":150},[152,652,653,673],{},[155,654,655,665,667,669,671],{},[158,656,657,659],{},[161,658,163],{},[155,660,661,663],{},[161,662,168],{},[161,664,171],{},[173,666,175],{},[177,668,179],{},[173,670,182],{},[177,672,185],{},[187,674,190],{"encoding":189},[59,676,678,725,743],{"className":677,"ariaHidden":195},[194],[59,679,681,684,716,719,722],{"className":680},[199],[59,682],{"className":683,"style":204},[203],[59,685,687,690],{"className":686},[208],[59,688,163],{"className":689},[208,212],[59,691,693],{"className":692},[216],[59,694,696],{"className":695},[220],[59,697,699],{"className":698},[224],[59,700,702],{"className":701,"style":229},[228],[59,703,704,707],{"style":232},[59,705],{"className":706,"style":237},[236],[59,708,71